# Database
DATABASE_URL="postgresql://user:password@localhost:5432/shelterlink"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-min-32-chars-change-in-production"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email Configuration (for OTP and notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@shelterlink.com"

# Payment Integration
STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

PAYSTACK_PUBLIC_KEY="pk_test_..."
PAYSTACK_SECRET_KEY="sk_test_..."

# File Upload (UploadThing)
UPLOADTHING_SECRET="your-uploadthing-secret"
UPLOADTHING_APP_ID="your-uploadthing-app-id"

# Maps (Mapbox)
NEXT_PUBLIC_MAPBOX_TOKEN="your-mapbox-token"
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Real-time (Pusher)
NEXT_PUBLIC_PUSHER_APP_KEY="your-pusher-app-key"
NEXT_PUBLIC_PUSHER_CLUSTER="mt1"
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_SECRET="your-pusher-secret"

# Analytics & Logging
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"

# App Configuration
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Commission Settings
NEXT_PUBLIC_RENTAL_COMMISSION=0.1
NEXT_PUBLIC_SALE_COMMISSION=0.1
NEXT_PUBLIC_SERVICE_COMMISSION=0.15
